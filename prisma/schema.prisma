// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ScheduledPostStatus {
  draft
  scheduled
  processing
  published
  failed
  needs_reconnect
  cancelled
}

enum Platform {
  x
  instagram
  facebook
}

enum ConnectedAccountStatus {
  active
  expired
  revoked
  error
}

enum PublishAttemptStatus {
  success
  failed
}

enum PostHistoryEventType {
  scheduled
  picked_up
  published
  failed
  cancelled
  retried
}

model ScheduledPost {
  id                  String              @id @default(uuid()) @map("id")
  // Phase 12.1-A expand step: nullable until backfill/constrain phases.
  ownerId             String              @map("owner_id")
  productId           String              @map("product_id")
  productName         String              @map("product_name")
  imageUrl            String?             @map("image_url")
  channels            Json                @map("channels")
  contentPayload      Json                @map("content_payload")
  scheduledAt         DateTime            @map("scheduled_at") @db.Timestamptz(6)
  status              ScheduledPostStatus @default(scheduled) @map("status")
  platform            Platform            @default(instagram) @map("platform")
  accountId           String?             @map("account_id")
  providerPostId      String?             @map("provider_post_id")
  providerUrl         String?             @map("provider_url")
  errorCode           String?             @map("error_code")
  publishedAt         DateTime?           @map("published_at") @db.Timestamptz(6)
  lastError           String?             @map("last_error")
  errorMessage        String?             @map("error_message")
  processedAt         DateTime?           @map("processed_at") @db.Timestamptz(6)
  lastAttemptAt       DateTime?           @map("last_attempt_at") @db.Timestamptz(6)
  attemptCount        Int                 @default(0) @map("attempt_count")
  idempotencyKey      String?             @unique @map("idempotency_key")
  processingStartedAt DateTime?           @map("processing_started_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  history             PostHistory[]
  account             ConnectedAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  attempts            PublishAttempt[]

  @@index([status, scheduledAt], map: "scheduled_posts_status_scheduled_at_idx")
  @@index([scheduledAt], map: "scheduled_posts_scheduled_at_idx")
  @@index([platform, status], map: "scheduled_posts_platform_status_idx")
  @@index([accountId], map: "scheduled_posts_account_id_idx")
  @@index([ownerId, status, scheduledAt], map: "scheduled_posts_owner_status_scheduled_at_idx")
  @@index([ownerId, createdAt], map: "scheduled_posts_owner_created_at_idx")
  @@map("scheduled_posts")
}

model PostHistory {
  id              String               @id @default(uuid()) @map("id")
  // Phase 12.1-A expand step: nullable until backfill/constrain phases.
  ownerId         String               @map("owner_id")
  scheduledPostId String               @map("scheduled_post_id")
  eventType       PostHistoryEventType @map("event_type")
  channel         String?              @map("channel")
  message         String?              @map("message")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  scheduledPost ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)

  @@index([scheduledPostId, createdAt], map: "post_history_scheduled_post_id_created_at_idx")
  @@index([ownerId, createdAt], map: "post_history_owner_created_at_idx")
  @@index([ownerId, scheduledPostId, createdAt], map: "post_history_owner_scheduled_post_id_created_at_idx")
  @@map("post_history")
}

model ConnectedAccount {
  id               String               @id @default(uuid()) @map("id")
  ownerId          String               @default("local-dev-user") @map("owner_id")
  platform         Platform             @map("platform")
  status           ConnectedAccountStatus @default(active) @map("status")
  externalAccountId String?             @map("external_account_id")
  displayName      String?              @map("display_name")
  accessToken      String?              @map("access_token")
  refreshToken     String?              @map("refresh_token")
  tokenExpiresAt   DateTime?            @map("token_expires_at") @db.Timestamptz(6)
  metadataJson     Json?                @map("metadata_json")
  lastError        String?              @map("last_error")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  posts    ScheduledPost[]
  attempts PublishAttempt[]

  @@index([platform, status], map: "connected_accounts_platform_status_idx")
  @@index([ownerId, platform, status], map: "connected_accounts_owner_platform_status_idx")
  @@map("connected_accounts")
}

model PublishAttempt {
  id            String             @id @default(uuid()) @map("id")
  // Phase 12.1-A expand step: nullable until backfill/constrain phases.
  ownerId       String             @map("owner_id")
  scheduledPostId String           @map("scheduled_post_id")
  accountId     String?            @map("account_id")
  platform      Platform           @map("platform")
  status        PublishAttemptStatus @map("status")
  errorCode     String?            @map("error_code")
  errorMessage  String?            @map("error_message")
  providerPostId String?           @map("provider_post_id")
  providerUrl   String?            @map("provider_url")
  rawResponse   Json?              @map("raw_response")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  scheduledPost ScheduledPost      @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
  account       ConnectedAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([scheduledPostId, createdAt], map: "publish_attempts_scheduled_post_id_created_at_idx")
  @@index([platform, status], map: "publish_attempts_platform_status_idx")
  @@index([ownerId, createdAt], map: "publish_attempts_owner_created_at_idx")
  @@index([ownerId, scheduledPostId, createdAt], map: "publish_attempts_owner_scheduled_post_id_created_at_idx")
  @@map("publish_attempts")
}

model OwnerEntitlement {
  id        String   @id @default(uuid()) @map("id")
  ownerId   String   @unique(map: "owner_entitlements_owner_id_key") @map("owner_id")
  planTier  String   @default("free") @map("plan_tier")
  status    String   @default("active") @map("status")
  source    String   @default("env") @map("source")
  effectiveAt DateTime @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by")
  notes     String?  @map("notes")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("owner_entitlements")
}

model EntitlementAuditLog {
  id               String   @id @default(uuid()) @map("id")
  ownerId          String   @map("owner_id")
  action           String   @map("action")
  previousPlanTier String?  @map("previous_plan_tier")
  nextPlanTier     String?  @map("next_plan_tier")
  previousStatus   String?  @map("previous_status")
  nextStatus       String?  @map("next_status")
  source           String   @map("source")
  actorOwnerId     String?  @map("actor_owner_id")
  notes            String?  @map("notes")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ownerId, createdAt], map: "entitlement_audit_logs_owner_created_at_idx")
  @@map("entitlement_audit_logs")
}

model BillingCustomer {
  id                 String   @id @default(uuid()) @map("id")
  ownerId            String   @unique(map: "billing_customers_owner_id_key") @map("owner_id")
  provider           String   @map("provider")
  providerCustomerId String   @map("provider_customer_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("billing_customers")
}

model BillingSubscription {
  id                     String    @id @default(uuid()) @map("id")
  ownerId                String    @map("owner_id")
  provider               String    @map("provider")
  providerSubscriptionId String    @unique(map: "billing_subscriptions_provider_subscription_id_key") @map("provider_subscription_id")
  status                 String    @map("status")
  periodStart            DateTime? @map("period_start") @db.Timestamptz(6)
  periodEnd              DateTime? @map("period_end") @db.Timestamptz(6)
  cancelAt               DateTime? @map("cancel_at") @db.Timestamptz(6)
  trialEnd               DateTime? @map("trial_end") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ownerId, status], map: "billing_subscriptions_owner_status_idx")
  @@map("billing_subscriptions")
}

model BillingWebhookEvent {
  id              String    @id @default(uuid()) @map("id")
  provider        String    @map("provider")
  providerEventId String    @map("provider_event_id")
  eventType       String    @map("event_type")
  payloadHash     String    @map("payload_hash")
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([provider, providerEventId], map: "billing_webhook_events_provider_event_id_key")
  @@map("billing_webhook_events")
}
